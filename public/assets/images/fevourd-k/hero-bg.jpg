="comp-lt8rm5ha1" tabindex="-1" class="Oqnisf comp-lt8rm5ha1 wixui-section" data-block-level-container="ClassicSection"><div id="bgLayers_comp-lt8rm5ha1" data-hook="bgLayers" data-motion-part="BG_LAYER comp-lt8rm5ha1" class="MW5IWV"><div data-testid="colorUnderlay" class="LWbAav Kv1aVt"></div><div id="bgMedia_comp-lt8rm5ha1" data-motion-part="BG_MEDIA comp-lt8rm5ha1" class="VgO9Yg"><wow-image id="img_comp-lt8rm5ha1" class="jhxvbR Kv1aVt dLPlxY mNGsUM bgImage" data-image-info="{&quot;containerId&quot;:&quot;comp-lt8rm5ha1&quot;,&quot;alignType&quot;:&quot;center&quot;,&quot;displayMode&quot;:&quot;fill&quot;,&quot;targetWidth&quot;:980,&quot;targetHeight&quot;:500,&quot;isLQIP&quot;:true,&quot;encoding&quot;:&quot;AVIF&quot;,&quot;imageData&quot;:{&quot;width&quot;:1200,&quot;height&quot;:667,&quot;uri&quot;:&quot;280683_4062d111497b4847812a02e56d886bf2~mv2.png&quot;,&quot;name&quot;:&quot;&quot;,&quot;displayMode&quot;:&quot;fill&quot;,&quot;hasAnimation&quot;:false}}" data-motion-part="BG_IMG comp-lt8rm5ha1" data-bg-effect-name="" data-has-ssr-src="true"><img src="https://static.wixstatic.com/media/280683_4062d111497b4847812a02e56d886bf2~mv2.png/v1/fill/w_45,h_25,al_c,q_85,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/280683_4062d111497b4847812a02e56d886bf2~mv2.png" alt="image.png" style="width:100%;height:100%;object-fit:cover;object-position:50% 50%" width="980" height="500"/></wow-image></div></div><div data-mesh-id="comp-lt8rm5ha1inlineContent" data-testid="inline-content" class=""><div data-mesh-id="comp-lt8rm5ha1inlineContent-gridContainer" data-testid="mesh-container-content"><div id="comp-jtftf1y6" class="Z_l5lU ku3DBC zQ9jDz qvSjx3 Vq6kJx comp-jtftf1y6 wixui-rich-text" data-testid="richTextElement"><h1 class="font_0 wixui-rich-text__text" style="line-height:normal; text-align:center; font-size:47px;"><span style="font-family:lato-light,lato,sans-serif;" class="wixui-rich-text__text"><span style="letter-spacing:normal;" class="wixui-rich-text__text"><span class="color_36 wixui-rich-text__text">About Us</span></span></span></h1></div><div id="comp-jrym5bei" class="Z_l5lU ku3DBC zQ9jDz qvSjx3 Vq6kJx comp-jrym5bei wixui-rich-text" data-testid="richTextElement"><h2 class="font_8 wixui-rich-text__text" style="font-size:22px; line-height:normal;"><span style="font-family:lato-light,lato,sans-serif;" class="wixui-rich-text__text"><span style="font-size:22px;" class="wixui-rich-text__text"><span style="letter-spacing:normal;" class="wixui-rich-text__text"><span class="color_18 wixui-rich-text__text">Federation of Voluntary Organisations for Urban and Rural Development in Karnataka (FEVOURD-K )</span></span></span></span></h2></div><div id="comp-m70dko8z" class="Z_l5lU ku3DBC zQ9jDz qvSjx3 Vq6kJx comp-m70dko8z wixui-rich-text" data-testid="richTextElement"><h2 class="font_8 wixui-rich-text__text" style="line-height:normal; font-size:17px;"><span style="font-family:lato-light,lato,sans-serif;" class="wixui-rich-text__text"><span class="color_36 wixui-rich-text__text"><span style="letter-spacing:normal;" class="wixui-rich-text__text">We help in boosting the productivity and effectiveness of our member organizations.</span></span></span></h2></div><div id="comp-m70dlo3y" class="Z_l5lU ku3DBC zQ9jDz qvSjx3 Vq6kJx comp-m70dlo3y wixui-rich-text" data-testid="richTextElement"><h2 class="font_8 wixui-rich-text__text" style="line-height:normal; text-align:justify; font-size:17px;"><span style="font-family:lato-light,lato,sans-serif;" class="wixui-rich-text__text"><span class="color_36 wixui-rich-text__text"><span style="letter-spacing:normal;" class="wixui-rich-text__text">FEVOURD-K is a federation of over 800 voluntary organisations committed to strengthening the developmental indices in Karnataka through social, economic and cultural empowerment of deprived communities, environmental conservation and the promotion of a vibrant democracy in the state.Founded on 1982</span></span><span style="letter-spacing:normal;" class="wixui-rich-text__text"><span class="color_36 wixui-rich-text__text">&nbsp;by visionary civil society leaders</span>,</span><span class="color_36 wixui-rich-text__text"><span style="letter-spacing:normal;" class="wixui-rich-text__text"> FEVOURD-K has a membership base in all the 31 districts of Karnataka. A robust voluntary sector &ndash; independent of governments, bureaucracy, and private corporations - is necessary for sustainable development and for democracy to thrive.</span></span></span></h2></div><div class="comp-kc927lit FubTgk" id="comp-kc927lit" aria-disabled="false"><a data-testid="linkElement" href="https://www.fevourd-k.org/about" target="_self" class="uDW_Qe wixui-button PlZyDq" aria-disabled="false" aria-label="Read More"><span class="l7_2fn wixui-button__label">Read More</span></a></div></div></div></section><section id="comp-lt8rm5hb" tabindex="-1" class="Oqnisf comp-lt8rm5hb wixui-section" data-block-level-container="ClassicSection"><div id="bgLayers_comp-lt8rm5hb" data-hook="bgLayers" data-motion-part="BG_LAYER comp-lt8rm5hb" class="MW5IWV"><div data-testid="colorUnderlay" class="LWbAav Kv1aVt"></div><div id="bgMedia_comp-lt8rm5hb" data-motion-part="BG_MEDIA comp-lt8rm5hb" class="VgO9Yg"></div></div><div data-mesh-id="comp-lt8rm5hbinlineContent" data-testid="inline-content" class=""><div data-mesh-id="comp-lt8rm5hbinlineContent-gridContainer" data-testid="mesh-container-content"><section id="comp-jrym9q5a" class="comp-jrym9q5a CohWsy wixui-column-strip"><div id="bgLayers_comp-jrym9q5a" data-hook="bgLayers" data-motion-part="BG_LAYER comp-jrym9q5a" class="if7Vw2"><div data-testid="colorUnderlay" class="tcElKx i1tH8h"></div><div id="bgMedia_comp-jrym9q5a" data-motion-part="BG_MEDIA comp-jrym9q5a" class="wG8dni"></div></div><div data-testid="columns" class="V5AUxf"><div id="comp-jrym9q89" class="comp-jrym9q89 YzqVVZ wixui-column-strip__column"><div id="bgLayers_comp-jrym9q89" data-hook="bgLayers" data-motion-part="BG_LAYER comp-jrym9q89" class="MW5IWV"><div da